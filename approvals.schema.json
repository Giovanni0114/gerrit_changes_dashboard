{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Gerrit Approvals Dashboard — Changes File",
    "description": "Tracked changes list for gerrit_approvals_dashboard. Settings live in approvals.toml.",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string"
        },
        "changes": {
            "type": "array",
            "description": "List of Gerrit changes to track",
            "items": {
                "type": "object",
                "properties": {
                    "host": {
                        "type": "string",
                        "description": "Gerrit SSH host"
                    },
                    "hash": {
                        "type": "string",
                        "description": "Git commit hash or Gerrit change-id",
                        "minLength": 1
                    },
                    "waiting": {
                        "type": "boolean",
                        "description": "When true, row is dimmed until an approval changes, then auto-set to false",
                        "default": false
                    },
                    "disabled": {
                        "type": "boolean",
                        "description": "When true, change is skipped during SSH queries and visually marked as disabled",
                        "default": false
                    },
                    "port": {
                        "type": "integer",
                        "description": "SSH port for this change, overrides default_port",
                        "minimum": 1,
                        "maximum": 65535
                    },
                    "comments": {
                        "type": "array",
                        "description": "User-attached notes for this change",
                        "items": {
                            "type": "string"
                        },
                        "default": []
                    },
                    "number": {
                        "type": "integer",
                        "description": "Gerrit change number (auto-discovered and persisted)",
                        "minimum": 1
                    }
                },
                "required": ["hash"],
                "additionalProperties": false
            }
        }
    },
    "required": ["changes"],
    "additionalProperties": false
}
